[Unit]
Description=Devops {{app_name}} SSL updater
Documentation=man:systemd.service(5)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/{{app_name}}
ExecStart=/bin/bash /opt/{{ app_name }}/scripts/ssl-updater.sh
TimeoutStartSec=600
PrivateTmp=yes
ProtectSystem=full
ReadWritePaths=/etc/{{app_name}}/
NoNewPrivileges=yes
